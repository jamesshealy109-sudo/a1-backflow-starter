---
import { company } from '../data/site.js';
---
<section class="intro section-pad" id="services">
  <div class="container split">
    <div class="reveal">
      <p class="eyebrow">What we do</p>
      <h2>Expert BackFlow Solutions</h2>
      <p>A-1 BackFlow Specialties provides professional backflow testing and solutions for customers who need the job done correctly, quickly, and without hassle.</p>
    </div>
    <div class="cards three reveal delay">
      <article><h3>Residential</h3><p>Annual backflow testing for homeowners, irrigation systems, and residential assemblies.</p></article>
      <article><h3>Commercial</h3><p>Reliable testing and documentation for businesses, facilities, and commercial properties.</p></article>
      <article><h3>Municipal</h3><p>Professional reporting support and service for utility compliance needs.</p></article>
    </div>
  </div>
</section>

<section class="pricing section-pad" id="pricing">
  <div class="container centered reveal">
    <p class="eyebrow">Simple pricing</p>
    <h2>Clear pricing. No confusion.</h2>
  </div>
  <div class="container cards price-grid">
    {company.prices.map((item) => (
      <article class="price-card reveal">
        <p>{item.label}</p>
        <strong>{item.price}</strong>
        <span>{item.detail}</span>
      </article>
    ))}
  </div>
</section>

<section class="process section-pad" id="process">
  <div class="container centered reveal">
    <p class="eyebrow">Easy process</p>
    <h2>Schedule. Test. Submit.</h2>
    <p>We keep backflow testing simple so you can stay compliant without chasing paperwork.</p>
  </div>
  <div class="container steps">
    <div class="step reveal"><b>01</b><h3>Schedule</h3><p>Call or send a message to schedule your annual backflow test.</p></div>
    <div class="step reveal"><b>02</b><h3>We Test</h3><p>A certified tester completes the inspection professionally.</p></div>
    <div class="step reveal"><b>03</b><h3>We File</h3><p>Reports are submitted to the appropriate water utility when required.</p></div>
  </div>
</section>

<section class="service-area section-pad">
  <div class="container split">
    <div class="reveal">
      <p class="eyebrow">Service area</p>
      <h2>Serving Lexington, Columbia, and surrounding communities.</h2>
      <p>Local service matters. A-1 BackFlow Specialties is built for fast response and reliable annual testing throughout the Midlands.</p>
    </div>
    <div class="area-grid reveal delay">
      {company.serviceArea.map((area) => <span>{area}</span>)}
    </div>
  </div>
</section>

<section class="faq section-pad" id="faq">
  <div class="container centered reveal">
    <p class="eyebrow">Questions</p>
    <h2>Backflow testing made simple.</h2>
  </div>
  <div class="container faq-list">
    <details open><summary>Do I need to be home?</summary><p>In many cases, no. It depends on where the backflow assembly is located and whether access is available.</p></details>
    <details><summary>How long does testing take?</summary><p>Most tests are quick, but timing depends on the assembly, location, and condition of the device.</p></details>
    <details><summary>Do you submit the report?</summary><p>Reports are submitted to the appropriate water utility when required.</p></details>
    <details><summary>What happens if it fails?</summary><p>If repairs are needed, A-1 BackFlow Specialties can review the issue and provide next steps.</p></details>
  </div>
</section>

<section class="cta section-pad" id="contact">
  <div class="container cta-box reveal">
    <div>
      <p class="eyebrow">Schedule today</p>
      <h2>Ready for your backflow test?</h2>
      <p>Call now or send a quick message to get on the schedule.</p>
    </div>
    <div class="contact-card">
      <a class="big-phone" href={company.phoneHref}>{company.phone}</a>
      <a href={`mailto:${company.email}`}>{company.email}</a>
      <p>{company.location}</p>
    </div>
  </div>
</section>
