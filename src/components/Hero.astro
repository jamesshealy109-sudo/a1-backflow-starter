---
import { company } from '../data/site.js';
---
<section class="hero section-pad">
  <div class="water-orb orb-one"></div>
  <div class="water-orb orb-two"></div>
  <div class="hero-grid container">
    <div class="hero-copy reveal">
      <p class="eyebrow">Certified Backflow Testing • Lexington, SC</p>
      <h1>{company.tagline}</h1>
      <p class="lead">Expert BackFlow Solutions for residential, commercial, and municipal customers throughout South Carolina.</p>
      <div class="hero-actions">
        <a class="btn primary" href={company.phoneHref}>Call {company.phone}</a>
        <a class="btn ghost" href="#contact">Schedule Your Test</a>
      </div>
      <div class="trust-row">
        <span>Certified Testers</span><span>Reports Submitted</span><span>Licensed & Insured</span>
      </div>
    </div>
    <div class="hero-card reveal delay">
      <div class="gauge-card">
        <span class="needle"></span>
        <p>Annual Testing</p>
        <strong>Handled Start to Finish</strong>
      </div>
      <div class="mini-card top">Protect Your Drinking Water</div>
      <div class="mini-card bottom">Fast. Local. Professional.</div>
    </div>
  </div>
</section>
