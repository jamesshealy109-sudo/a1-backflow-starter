---
import '../styles/global.css';
const { title = 'A-1 BackFlow Specialties', description = 'Certified backflow testing and backflow solutions in Lexington, Columbia, and surrounding South Carolina communities.' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#a7d8f0" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${Astro.site}${import.meta.env.BASE_URL}assets/og-card.svg`} />
  </head>
  <body>
    <slot />
  </body>
</html>
